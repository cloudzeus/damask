generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── RBAC ─────────────────────────────────────────────
model User {
  id             String            @id @default(cuid())
  email          String            @unique
  name           String
  passwordHash   String
  active         Boolean           @default(true)
  roleId         String
  role           Role              @relation(fields: [roleId], references: [id])
  trdrId         String?
  trdr           Trdr?             @relation(fields: [trdrId], references: [id])
  architect      ArchitectProfile?
  contact        Contact?
  phone          String?
  mobile         String?
  address        String?
  city           String?
  country        String?
  createdOrders  Order[]           @relation("OrderCreatedBy")
  approvedOrders Order[]           @relation("OrderApprovedBy")
  importJobs     ImportJob[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  managedApplications   ProgramApplication[]    @relation("AppManager")
  processedApplications ProgramApplication[]    @relation("AppProcessor")
  assignedObligations   ApplicationObligation[]

  @@index([roleId])
  @@index([trdrId])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  system      Boolean          @default(false) // προστατευμένοι (δεν διαγράφονται): SUPER_ADMIN, ADMIN, MANAGER, EMPLOYEE, CUSTOMER
  b2b         Boolean          @default(false) // true → home /portal (B2B), false → /dashboard
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique // π.χ. "product.edit"
  description String
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ── SoftOne infra ────────────────────────────────────
/// Singleton row — always upsert with where:{id:1}, never create()
model S1Session {
  id       Int    @id @default(1)
  clientId String
  date     String // YYYY-MM-DD — ισχύει για μία μέρα
}

model SyncLog {
  id        String   @id @default(cuid())
  entity    String // "product" | "customer" | ...
  action    String // "pull" | "push" | "verify"
  s1Key     String?
  ok        Boolean
  message   String?
  request   Json?
  response  Json?
  createdAt DateTime @default(now())

  @@index([entity, createdAt])
}

enum OutboxStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

model S1Outbox {
  id         String       @id @default(cuid())
  object     String // S1 OBJECT π.χ. "ITEM", "CUSTOMER", "SALDOC"
  s1Key      String? // KEY για update, null για insert
  payload    Json
  status     OutboxStatus @default(PENDING)
  attempts   Int          @default(0)
  lastError  String?
  verifiedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([status, createdAt])
}

// ── Ταξινομήσεις & ΜΜ ────────────────────────────────
model Category {
  id       String    @id @default(cuid())
  s1Id     Int       @unique
  name     String
  nameEn   String?
  products Product[]
}

model Group {
  id       String    @id @default(cuid())
  s1Id     Int       @unique
  name     String
  nameEn   String?
  products Product[]

  @@map("ProductGroup")
}

model Subgroup {
  id       String    @id @default(cuid())
  s1Id     Int       @unique
  name     String
  nameEn   String?
  products Product[]
}

model Unit {
  id          String    @id @default(cuid())
  s1Id        Int       @unique
  code        String?
  name        String
  purchaseFor Product[] @relation("PurchaseUnit")
  salesFor    Product[] @relation("SalesUnit")
}

// ── Προϊόντα ─────────────────────────────────────────
enum ProductStatus {
  DRAFT
  COMPLETE
  PUBLISHED
}

enum ReviewStatus {
  NEEDS_REVIEW
  APPROVED
}

model Product {
  id             String               @id @default(cuid())
  mtrl           Int?                 @unique // S1 id — NULL για προϊόντα που δημιουργήθηκαν από Excel import και δεν έχουν ακόμα συγχρονιστεί με το SoftOne (nullable unique είναι ok σε Postgres· πολλαπλά NULL επιτρέπονται)
  code           String               @unique
  isActive       Boolean              @default(true)
  status         ProductStatus        @default(DRAFT)
  priceWholesale Decimal?             @db.Decimal(14, 4)
  priceRetail    Decimal?             @db.Decimal(14, 4)
  stock          Decimal?             @db.Decimal(14, 4)
  cbmPerUnit     Decimal?             @db.Decimal(10, 4)
  weightPerUnit  Decimal?             @db.Decimal(10, 3)
  categoryId     String?
  category       Category?            @relation(fields: [categoryId], references: [id])
  groupId        String?
  group          Group?               @relation(fields: [groupId], references: [id])
  subgroupId     String?
  subgroup       Subgroup?            @relation(fields: [subgroupId], references: [id])
  purchaseUnitId String?
  purchaseUnit   Unit?                @relation("PurchaseUnit", fields: [purchaseUnitId], references: [id])
  salesUnitId    String?
  salesUnit      Unit?                @relation("SalesUnit", fields: [salesUnitId], references: [id])
  unitFactor     Decimal?             @db.Decimal(12, 6) // ΜΜ αγοράς → ΜΜ πώλησης
  translations   ProductTranslation[]
  media          MediaAsset[]
  orderLines     OrderLine[]
  priceCache     PriceCache[]
  s1UpdatedAt    DateTime?
  syncedAt       DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([status])
  @@index([code])
  @@index([categoryId])
  @@index([groupId])
  @@index([subgroupId])
}

model ProductTranslation {
  id                String       @id @default(cuid())
  productId         String
  product           Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  locale            String // "el" | "en"
  name              String
  shortDescription  String?
  description       String?
  seoTitle          String?
  seoDescription    String?
  machineTranslated Boolean      @default(false)
  reviewStatus      ReviewStatus @default(NEEDS_REVIEW)

  @@unique([productId, locale])
}

enum MediaType {
  IMAGE
  VIDEO
  MODEL_3D
  FILE
}

model MediaFolder {
  id        String        @id @default(cuid())
  name      String
  parentId  String?
  parent    MediaFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  MediaFolder[] @relation("FolderTree")
  assets    MediaAsset[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([parentId, name])
  @@index([parentId])
}

model MediaAsset {
  id        String       @id @default(cuid())
  productId String?
  product   Product?     @relation(fields: [productId], references: [id], onDelete: Cascade)
  folderId  String?
  folder    MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  name      String
  alt       String?
  type      MediaType
  cdnUrl    String
  size      Int?
  mimeType  String?
  sortOrder Int          @default(0)
  meta      Json?
  createdAt DateTime     @default(now())

  @@index([productId, sortOrder])
  @@index([folderId])
}

// ── Συναλλασσόμενοι (TRDR) / Επαφές / Αρχιτέκτονες ───
/// EXACT SoftOne TRDR mapping (CUSTOMER.CUSTOMER / SUPPLIER.SUPPLIER — ίδιος
/// υποκείμενος πίνακας TRDR στο SoftOne, διαφοροποιείται με SODTYPE). Τα
/// πεδία με uppercase ονόματα είναι 1-προς-1 SoftOne (βλ. trdr-schema.json) —
/// ΟΧΙ δικά μας ονόματα/mapping layer. Πεδία με πρόθεμα "app" είναι δικές μας
/// επεκτάσεις εκτός SoftOne (ΠΟΤΕ δεν στέλνονται/λαμβάνονται από S1 sync).
/// ISPROSP = 1 σημαίνει «Υποψήφιος» (lead) — αυτό ΕΙΝΑΙ το lead flag, όχι
/// ξεχωριστό enum status. SODTYPE 13 = Πελάτης, 12 = Προμηθευτής (καθορίζει
/// tab στο /partners). COUNTRY/TRDCATEGORY/TRDPGROUP/TRDBUSINESS/PAYMENT/
/// SHIPMENT/SOCURRENCY είναι soft references (Int, χωρίς Prisma @relation)
/// στα mirror tables παρακάτω — τα combos τα φορτώνουν με ξεχωριστό query,
/// όχι Prisma relation, ώστε η σειρά sync (S1 reference data πριν τα TRDR) να
/// μην είναι FK-constrained.
model Trdr {
  id           String              @id @default(cuid())
  TRDR         Int?                @unique // null = καρτέλα που δεν έχει συγχρονιστεί ακόμα με SoftOne (π.χ. δημιουργήθηκε από OCR)
  SODTYPE      Int                 @default(13) // 13 = Πελάτης, 12 = Προμηθευτής
  CODE         String?
  NAME         String
  AFM          String?
  IRSDATA      String? // κωδ.Δ.Ο.Υ. (soft ref στο mirror Irsdata.CODE — string κωδικός, ΟΧΙ το Irsdata.IRSDATA numeric id)
  JOBTYPETRD   String? // επάγγελμα, free text
  ADDRESS      String?
  ZIP          String?
  DISTRICT     String?
  CITY         String?
  COUNTRY      Int? // soft ref Country.COUNTRY
  PHONE01      String?
  PHONE02      String?
  FAX          String?
  EMAIL        String?
  WEBPAGE      String?
  TRDCATEGORY  Int? // soft ref TrdCategory.TRDCATEGORY
  TRDPGROUP    Int?
  TRDBUSINESS  Int?
  PAYMENT      Int? // soft ref S1Payment.PAYMENT
  SHIPMENT     Int? // soft ref Shipment.SHIPMENT
  SOCURRENCY   Int?                @default(100) // 100 = ΕΥΡΩ (default SoftOne)
  ISACTIVE     Int                 @default(1)
  ISPROSP      Int                 @default(0) // 1 = Υποψήφιος (lead flag)
  REMARKS      String?
  CODE1        String?
  UPDDATE      DateTime? // τελευταία μεταβολή στο SoftOne
  // ── app extras (ΟΧΙ SoftOne) ──
  appLat       Float?
  appLng       Float?
  appLogoUrl   String?
  appLegalForm String?
  appNotes     String?
  syncedAt     DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  users        User[]
  contacts     Contact[]
  orders       Order[]
  architects   ArchitectCustomer[]
  priceCache   PriceCache[]
  formRecords     TrdrFormRecord[]
  financialValues TrdrFinancialValue[]
  programApplications ProgramApplication[]

  @@index([SODTYPE, ISPROSP])
  @@index([SODTYPE, ISACTIVE])
  @@index([AFM])
}

model Contact {
  id        String  @id @default(cuid())
  trdrId    String
  trdr      Trdr    @relation(fields: [trdrId], references: [id], onDelete: Cascade)
  /// Mirror CUSPRSN/SUPPRSN pattern (S1 person-on-trader link) — PRSN = S1
  /// person id (PRSN→PRSNOUT στο S1 export), TRDBRANCH/LINENUM = θέση μέσα
  /// στην CUSPRSN/SUPPRSN γραμμή, COMMENTS = παρατηρήσεις S1.
  PRSN      Int?
  TRDBRANCH Int?
  LINENUM   Int?
  COMMENTS  String?
  name      String
  position  String?
  email     String?
  phone     String?
  mobile    String?
  isPrimary Boolean @default(false)
  /// Σύνδεση με User όταν εγκρίνεται το αίτημα πρόσβασης της επαφής (βλ.
  /// approveAccessRequest, src/app/(app)/users/actions.ts) — ίδιο idiom με
  /// ArchitectProfile.userId παρακάτω.
  userId    String? @unique
  user      User?   @relation(fields: [userId], references: [id])

  @@index([trdrId])
}

model ArchitectProfile {
  id            String              @id @default(cuid())
  userId        String              @unique
  user          User                @relation(fields: [userId], references: [id])
  commissionPct Decimal             @db.Decimal(5, 2) // default %
  customers     ArchitectCustomer[]
  commissions   CommissionEntry[]
  orders        Order[]
}

model ArchitectCustomer {
  architectId String
  trdrId      String
  architect   ArchitectProfile @relation(fields: [architectId], references: [id], onDelete: Cascade)
  trdr        Trdr             @relation(fields: [trdrId], references: [id], onDelete: Cascade)

  @@id([architectId, trdrId])
  @@index([trdrId])
}

// ── S1 reference mirrors (VAT/COUNTRY/IRSDATA/TRDCATEGORY/PAYMENT/
// SHIPMENT/SOCURRENCY/SERIES) ─────────────────────────
/// Synced from SoftOne via src/lib/s1-sync.ts (syncS1Reference/syncAllReferences,
/// pg-boss queue 's1-ref-sync'). Πεδία ΑΚΡΙΒΩΣ όπως στο SoftOne (βλ.
/// trdr-schema.json). ISACTIVE=1 φιλτράρεται στα combo components
/// (src/components/s1/*Select.tsx).
model Vat {
  VAT        Int    @id
  NAME       String
  PERCNT     Float
  VATS1      Int?
  ISACTIVE   Int    @default(1)
  MYDATACODE Int?
}

model Country {
  COUNTRY     Int     @id
  SHORTCUT    String
  NAME        String
  SOCURRENCY  Int?
  COUNTRYTYPE Int?
  INTCODE     String?
  INTERCODE   String?
  EANCODE     String?
  ISACTIVE    Int     @default(1)
}

model Irsdata {
  IRSDATA  Int     @id
  CODE     String?
  NAME     String
  ISACTIVE Int     @default(1)
  ADDRESS  String?
  CITY     String?
  ZIP      String?
  PHONE1   String?
  EMAIL    String?
}

model TrdCategory {
  TRDCATEGORY Int    @id
  CODE        String
  NAME        String
  VATSTS      Int?
  ISACTIVE    Int    @default(1)
}

/// Ονομάστηκε S1Payment (@@map "S1Payment") για να μην συγκρούεται με τα
/// υπάρχοντα enum PaymentStatus/model PaymentOrder (Viva Payments — βλ.
/// παρακάτω) που είναι εντελώς άσχετο domain.
model S1Payment {
  PAYMENT     Int    @id
  CODE        String
  NAME        String
  ISACTIVE    Int    @default(1)
  MYDATACODE  Int?
  INSTALMENTS Int?

  @@map("S1Payment")
}

model Shipment {
  SHIPMENT Int     @id
  CODE     String
  NAME     String
  INTCODE  String?
  ISACTIVE Int     @default(1)
}

model SoCurrency {
  SOCURRENCY Int     @id
  SHORTCUT   String
  NAME       String
  ISACTIVE   Int     @default(1)
  INTERCODE  String?
  LRATE      Float?
}

/// Curated (ΟΧΙ όλα τα πεδία SERIES.SERIES — 60+ πεδία εκτύπωσης/λογιστικής
/// άσχετα με trading-partner combos). Μόνο ό,τι χρειάζεται για SERIES combo
/// (βλ. AGENTS.md §3).
model Series {
  SERIES   Int     @id
  SODTYPE  Int
  CODE     String?
  NAME     String
  ISACTIVE Int     @default(1)
}

// ── Containers & Τιμολόγηση ──────────────────────────
enum ContainerStatus {
  OPEN
  CLOSED
  ORDERED
  SHIPPED
  RECEIVED
}

model Container {
  id           String          @id @default(cuid())
  name         String
  supplierName String?
  capacityCbm  Decimal         @db.Decimal(10, 3)
  freightCost  Decimal         @db.Decimal(14, 2)
  status       ContainerStatus @default(OPEN)
  overrides    Json? // per-item/σταθερά overrides τιμών
  orderLines   OrderLine[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model PriceCache {
  trdrId    String
  productId String
  price     Decimal  @db.Decimal(14, 4)
  fetchedAt DateTime @default(now())
  trdr      Trdr     @relation(fields: [trdrId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([trdrId, productId])
}

// ── Παραγγελίες ──────────────────────────────────────
enum OrderStatus {
  DRAFT
  SUBMITTED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SYNCED_TO_S1
}

model Order {
  id           String            @id @default(cuid())
  trdrId       String
  trdr         Trdr              @relation(fields: [trdrId], references: [id])
  createdById  String
  createdBy    User              @relation("OrderCreatedBy", fields: [createdById], references: [id])
  architectId  String?
  architect    ArchitectProfile? @relation(fields: [architectId], references: [id])
  status       OrderStatus       @default(DRAFT)
  s1Findoc     Int?
  notes        String?
  approvedById String?
  approvedBy   User?             @relation("OrderApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  rejectReason String?
  lines        OrderLine[]
  commission   CommissionEntry?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([trdrId])
}

model OrderLine {
  id           String     @id @default(cuid())
  orderId      String
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  qty          Decimal    @db.Decimal(14, 4)
  unitPrice    Decimal    @db.Decimal(14, 4) // ΚΛΕΙΔΩΜΕΝΗ τη στιγμή της παραγγελίας
  freightShare Decimal?   @db.Decimal(14, 4)
  cbmReserved  Decimal?   @db.Decimal(10, 3)
  containerId  String?
  container    Container? @relation(fields: [containerId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([containerId])
}

model CommissionEntry {
  id          String           @id @default(cuid())
  orderId     String           @unique
  order       Order            @relation(fields: [orderId], references: [id])
  architectId String
  architect   ArchitectProfile @relation(fields: [architectId], references: [id])
  pct         Decimal          @db.Decimal(5, 2)
  amount      Decimal          @db.Decimal(14, 2)
  createdAt   DateTime         @default(now())

  @@index([architectId])
}

// ── Πληρωμές (Viva Payments — viva.com) ───────────────
/// Κατάσταση μοναδικού κωδικού πληρωμής Viva (orderCode): PENDING μέχρι να έρθει
/// webhook event, PAID/FAILED από το webhook (1796/1797), EXPIRED από «Έλεγχος
/// κατάστασης» όταν η Viva επιστρέφει ληγμένη παραγγελία, CANCELED = τοπική
/// ακύρωση χρήστη (δεν ακυρώνει τίποτα στο Viva, μόνο κρύβει από τα «ενεργά»).
enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELED
}

/// customerId/createdById είναι σκόπιμα ΧΩΡΙΣ @relation (soft reference, όπως
/// AccessRequest παραπάνω) — το PaymentOrder μένει αυτόνομο από Customer/User
/// modeling churn· βλ. src/lib/viva.ts για τη λογική δημιουργίας/webhook update.
model PaymentOrder {
  id            String        @id @default(cuid())
  orderCode     String        @unique // Viva 16-digit — ο «μοναδικός κωδικός πληρωμής»
  amountCents   Int
  description   String
  customerName  String?
  customerEmail String?
  customerId    String? // soft link σε Customer αν επιλέχθηκε από τη λίστα
  environment   String // "demo" | "production" — με ΠΟΙΟ env δημιουργήθηκε
  status        PaymentStatus @default(PENDING)
  transactionId String?
  paidAt        DateTime?
  raw           Json? // τελευταίο ωφέλιμο φορτίο Viva (order create ή webhook event)
  createdById   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([customerId])
}

// ── Import/Export (οριζόντιο — spec §11α) ────────────
model ImportMapping {
  id        String   @id @default(cuid())
  entity    String // "product" | "customer" | "order" | ...
  name      String
  columnMap Json // { "Στήλη Excel": "πεδίο μοντέλου", ... }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([entity, name])
}

model DocumentTemplate {
  id        String   @id @default(cuid())
  type      String // "offer" | "report"
  name      String
  config    Json // κείμενα, headers, branding επιλογές
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, name])
}

/// Καταγραφή εκτέλεσης εισαγωγής Excel (Import Engine, spec §11α). Δημιουργείται
/// πάντα στο Βήμα 5 (Εκτέλεση) — sync εκτελέσεις (≤500 γραμμές) καταλήγουν κατευθείαν
/// DONE/FAILED· μεγαλύτερες πάνε PENDING→RUNNING μέσω pg-boss job στην ουρά 'import'
/// (src/server/queue-start.ts) με progress ορατό από GET /api/import/status/[id].
enum ImportJobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

model ImportJob {
  id           String          @id @default(cuid())
  entity       String // "product" | ... (μελλοντικές οντότητες)
  status       ImportJobStatus @default(PENDING)
  totals       Json? // { total, created, updated, failed, errors: [{row,column,message}] } — πρώτα 50 errors
  errorFileUrl String? // προαιρετικό — v1 κατεβάζει το Excel σφαλμάτων client-side από τα totals.errors
  createdById  String
  createdBy    User            @relation(fields: [createdById], references: [id])
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([status, createdAt])
  @@index([entity, createdAt])
}

// ── Auth: B2B access requests & password reset ───────
enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model AccessRequest {
  id        String              @id @default(cuid())
  type      String // "CUSTOMER" | "ARCHITECT" | "SUPPLIER"
  name      String
  company   String
  afm       String
  phone     String
  email     String              @unique
  /// Αίτημα καταχωρημένο από επαφή (⋮ «Αίτημα πρόσβασης user» στο /partners/[id])
  /// αντί για το δημόσιο /register — ΧΩΡΙΣ @relation (soft reference, ίδιο idiom
  /// με PaymentOrder.createdById παραπάνω). approveAccessRequest το διαβάζει για
  /// να γράψει πίσω Contact.userId + User.customerId.
  contactId String?
  status    AccessRequestStatus @default(PENDING)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([status, createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ── Settings (key/value) ──────────────────────────────
/// Γενικό key/value store ρυθμίσεων — integrations ("integration.mailgun"),
/// προφίλ εταιρείας ("company.profile"), SEO defaults ("seo.defaults").
/// Secrets αποθηκεύονται εδώ ως Json (αποδεκτό για v1 — plaintext στη DB,
/// βλ. concern για encryption σε φάση hardening). Κάθε integration value
/// μπορεί να κουβαλά ένα εσωτερικό "_lastCheck": {ok,message,at} από το
/// τελευταίο «Δοκιμή σύνδεσης». src/lib/settings.ts είναι το μοναδικό
/// σημείο πρόσβασης (getSetting/setSetting/getIntegration).
model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// ── DB Backups (BunnyCDN) ──────────────────────────────
enum DbBackupStatus {
  PENDING
  READY
  FAILED
  RESTORING
}

/// Ημερήσια αντίγραφα ασφαλείας της DB σε BunnyCDN (καρτέλα «Backups» στο
/// /settings). pg_dump -F c μέσω src/lib/backup.ts· trigger 'cron' (pg-boss
/// queue 'backup', src/server/queue-start.ts, καθημερινά 03:30 Europe/Athens)
/// ή 'manual' (κουμπί «Backup τώρα» ΚΑΙ το αυτόματο safety backup που τρέχει
/// πριν από κάθε restore — αναγνωρίζεται από το πρόθεμα "pre-restore-" στο
/// filename, όχι ξεχωριστό trigger). createdById ΧΩΡΙΣ @relation (soft
/// reference, ίδιο idiom με PaymentOrder.createdById παραπάνω) — τα cron
/// backups δεν έχουν χρήστη.
model DbBackup {
  id           String         @id @default(cuid())
  filename     String
  storageKey   String         @unique
  sizeBytes    BigInt         @default(0)
  status       DbBackupStatus @default(PENDING)
  trigger      String // "cron" | "manual"
  errorMessage String?
  createdById  String?
  createdAt    DateTime       @default(now())

  @@index([status, createdAt])
}

// ── CMS: Άρθρα / «Νέα» ─────────────────────────────────
enum PostStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

model Author {
  id        String   @id @default(cuid())
  name      String
  bio       String?
  avatarUrl String?
  userId    String?  @unique // προαιρετική σύνδεση με User
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PostCategory {
  id           String                    @id @default(cuid())
  slug         String                    @unique
  translations PostCategoryTranslation[]
  posts        Post[]
  createdAt    DateTime                  @default(now())
}

model PostCategoryTranslation {
  id         String       @id @default(cuid())
  categoryId String
  category   PostCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  locale     String // "el" | "en"
  name       String

  @@unique([categoryId, locale])
}

model Post {
  id            String            @id @default(cuid())
  slug          String            @unique
  status        PostStatus        @default(DRAFT)
  authorId      String?
  author        Author?           @relation(fields: [authorId], references: [id])
  categoryId    String?
  category      PostCategory?     @relation(fields: [categoryId], references: [id])
  featuredImage String? // cdn url
  publishedAt   DateTime?
  aiGenerated   Boolean           @default(false)
  translations  PostTranslation[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status, publishedAt])
}

model PostTranslation {
  id                String  @id @default(cuid())
  postId            String
  post              Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  locale            String // "el" | "en"
  title             String
  excerpt           String?
  body              String // markdown
  seoTitle          String?
  seoDescription    String?
  machineTranslated Boolean @default(false)

  @@unique([postId, locale])
}

// ── Legal pages & Consent ─────────────────────────────
model LegalPage {
  id           String                 @id @default(cuid())
  slug         String                 @unique // privacy-policy, terms, cookies, returns, shipping, gdpr-rights
  published    Boolean                @default(false)
  translations LegalPageTranslation[]
  updatedAt    DateTime               @updatedAt
  createdAt    DateTime               @default(now())
}

model LegalPageTranslation {
  id                String    @id @default(cuid())
  pageId            String
  page              LegalPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  locale            String // el | en
  title             String
  body              String // markdown
  machineTranslated Boolean   @default(false)

  @@unique([pageId, locale])
}

model ConsentLog {
  id            String   @id @default(cuid())
  visitorId     String // anonymous cookie uuid
  userId        String? // αν logged in
  ip            String
  userAgent     String
  os            String // parsed
  browser       String? // parsed
  locale        String?
  choices       Json // { necessary: true, analytics: bool, marketing: bool }
  policyVersion String? // από setting
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([visitorId])
}

// ── AI/API cost tracking (src/lib/ai/*) ─────────────────
/// Μία γραμμή ανά κλήση σε AI provider (DeepSeek/Gemini/Claude/…), γραμμένη
/// fire-and-forget από logAiUsage (src/lib/ai/usage.ts — ΠΟΤΕ δεν πετάει).
/// inputCost/outputCost/totalCost σε USD, null όταν το μοντέλο δεν αναγνωρίστηκε
/// στο pricing table (src/lib/ai/pricing.ts) ΟΥΤΕ σε override (setting
/// "ai.pricingOverrides") — η σελίδα /costs τα μετατρέπει σε EUR (src/lib/ai/fx.ts)
/// και εφαρμόζει markup ανά provider (setting "ai.markup", SUPER_ADMIN-only) κατά
/// το render, όχι εδώ· η γραμμή μένει πάντα «καθαρό» base cost. userId/refType/refId
/// ΧΩΡΙΣ @relation (soft reference, ίδιο idiom με PaymentOrder.createdById παραπάνω).
model AiUsage {
  id           String   @id @default(cuid())
  scope        String // "OCR_TEXT" | "OCR_VISION" | "TRANSLATION" | "CMS_GENERATE" | "OTHER"
  provider     String // "deepseek" | "gemini" | "claude" | ...
  model        String
  operation    String?
  inputTokens  Int
  outputTokens Int
  totalTokens  Int
  inputCost    Float? // USD
  outputCost   Float? // USD
  totalCost    Float? // USD
  durationMs   Int?
  userId       String?
  refType      String?
  refId        String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([provider, createdAt])
}

/// Μετρημένη χρήση API υπηρεσιών (ΟΧΙ AI — αυτά μένουν στο AiUsage): Mailgun
/// (per_email), BunnyCDN (per_gb, μόνο uploads μέσω δικών μας routes), Viva
/// (per_transaction, ενημερωτικά), ΑΑΔΕ/vat.wwa.gr (per_lookup), geocoding
/// (per_request — θα ενεργοποιηθεί με το traders task). units: emails=1,
/// GB=δεκαδικός (bytes/1e9), lookups/συναλλαγές=1. costEur = ακατέργαστο κόστος
/// ΤΗΣ ΓΡΑΜΜΗΣ σε EUR (units × basePrice κατά τη στιγμή του logging) — ΧΩΡΙΣ
/// markup ΚΑΙ ΧΩΡΙΣ την έκπτωση free quota (αυτή εφαρμόζεται ΜΙΑ φορά στο
/// μηνιαίο άθροισμα μονάδων ανά service — βλ. computeMonthlyCost στο
/// src/lib/api-costs.ts — όχι per-row, ίδιο idiom με το AiUsage.totalCost που
/// είναι base cost πριν το markup, το οποίο εφαρμόζεται στο render).
model ApiUsage {
  id        String   @id @default(cuid())
  service   String // "mailgun" | "bunnycdn" | "viva" | "aade" | "geocoding"
  operation String?
  units     Float
  costEur   Float?
  userId    String?
  refType   String?
  refId     String?
  createdAt DateTime @default(now())

  @@index([service, createdAt])
}

enum TaxTemplateStatus {
  DRAFT
  READY
}

enum TaxFieldKind {
  SINGLE
  SERIES
  TABLE
}

enum FinancialValueType {
  CURRENCY
  NUMBER
  PERCENT
  INTEGER
  DATE
  BOOLEAN
}

enum FinancialValueSource {
  OCR
  MANUAL
}

model TaxFormTemplate {
  id               String   @id @default(cuid())
  code             String
  name             String
  year             Int?
  description      String?
  status           TaxTemplateStatus @default(DRAFT)
  sampleStorageKey String?
  samplePageCount  Int?
  sampleThumbUrl   String?
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  fields           TaxFormTemplateField[]
  records          TrdrFormRecord[]
  requiredForms    ProgramRequiredForm[]
  @@unique([code, year])
  @@index([status])
}

model TaxFormTemplateField {
  id          String   @id @default(cuid())
  templateId  String
  template    TaxFormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fieldKey    String
  label       String
  section     String?
  valueType   FinancialValueType @default(CURRENCY)
  kind        TaxFieldKind @default(SINGLE)
  config      Json?
  regionHint  Json?
  aiHint      String?
  required    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([templateId, fieldKey])
  @@index([templateId])
}

model TrdrFormRecord {
  id            String   @id @default(cuid())
  name          String
  usage         String?
  trdrId        String
  trdr          Trdr     @relation(fields: [trdrId], references: [id], onDelete: Cascade)
  templateId    String
  template      TaxFormTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  year          Int
  storageKey    String
  pageCount     Int?
  status        String   @default("PENDING")
  extractedData Json?
  model         String?
  tokensUsed    Int?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  values        TrdrFinancialValue[]
  @@index([trdrId])
  @@index([templateId])
  @@index([trdrId, year])
}

model TrdrFinancialValue {
  id               String   @id @default(cuid())
  trdrId           String
  trdr             Trdr     @relation(fields: [trdrId], references: [id], onDelete: Cascade)
  fieldKey         String
  templateId       String?
  year             Int
  value            Decimal? @db.Decimal(18, 2)
  valueText        String?
  valueJson        Json?
  kind             TaxFieldKind @default(SINGLE)
  valueType        FinancialValueType
  source           FinancialValueSource @default(OCR)
  sourceRecordId   String?
  sourceRecord     TrdrFormRecord? @relation(fields: [sourceRecordId], references: [id], onDelete: SetNull)
  confidence       Float?
  verified         Boolean  @default(false)
  verifiedById     String?
  note             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  @@unique([trdrId, fieldKey, year])
  @@index([trdrId])
  @@index([fieldKey, year])
}

enum ProgramStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum ProgramExtractStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum ProgramBonusKind {
  SPEED
  INNOVATION
  GREEN
  EMPLOYMENT
  OTHER
}

enum ExpenseSuggestSource {
  AI
  MANUAL
}

model Program {
  id                  String                     @id @default(cuid())
  title               String
  summary             String?
  referenceCode       String?
  sourceFileName      String?
  storageKey          String?                    @unique
  mimeType            String?
  size                Int?
  publicationDate     DateTime?
  submissionStart     DateTime?
  submissionEnd       DateTime?
  totalBudget         Decimal?                   @db.Decimal(18, 2)
  fundingRate         Decimal?                   @db.Decimal(5, 2)
  durationMonths      Int?
  minEmployeesFte     Decimal?                   @db.Decimal(10, 2)
  minOperationalYears Decimal?                   @db.Decimal(5, 2)
  eligibilityNote     String?
  status              ProgramStatus              @default(DRAFT)
  extractStatus       ProgramExtractStatus       @default(PENDING)
  extractedData       Json?
  model               String?
  tokensUsed          Int?
  errorMessage        String?
  notes               String?
  createdById         String?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  expenseCats         ProgramExpenseCategory[]
  kads                ProgramKad[]
  bonuses             ProgramBonus[]
  criteria            ProgramCriterion[]
  deadlines           ProgramDeadline[]
  phases              ProgramPhase[]
  deliverables        ProgramDeliverable[]
  regions             ProgramRegion[]
  legalForms          ProgramEligibleLegalForm[]
  applications        ProgramApplication[]
  requiredForms       ProgramRequiredForm[]

  @@index([status])
  @@index([extractStatus])
  @@index([submissionEnd])
}

model ProgramExpenseCategory {
  id            String           @id @default(cuid())
  programId     String
  program       Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  name          String
  minAmount     Decimal?         @db.Decimal(18, 2)
  maxAmount     Decimal?         @db.Decimal(18, 2)
  minPercentage Decimal?         @db.Decimal(5, 2)
  maxPercentage Decimal?         @db.Decimal(5, 2)
  mandatory     Boolean          @default(false)
  notes         String?
  order         Int              @default(0)
  expenses      ProgramExpense[]

  @@index([programId])
}

model ProgramKad {
  id          String  @id @default(cuid())
  programId   String
  program     Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  code        String
  description String?

  @@index([programId])
}

model ProgramBonus {
  id          String           @id @default(cuid())
  programId   String
  program     Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  kind        ProgramBonusKind @default(OTHER)
  name        String
  condition   String?
  bonusRate   Decimal?         @db.Decimal(5, 2)
  bonusAmount Decimal?         @db.Decimal(18, 2)
  order       Int              @default(0)

  @@index([programId])
}

model ProgramCriterion {
  id        String   @id @default(cuid())
  programId String
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  name      String
  weight    Decimal? @db.Decimal(5, 2)
  notes     String?
  order     Int      @default(0)

  @@index([programId])
}

model ProgramDeadline {
  id        String    @id @default(cuid())
  programId String
  program   Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  name      String
  date      DateTime?
  notes     String?
  order     Int       @default(0)

  @@index([programId])
}

model ProgramPhase {
  id           String               @id @default(cuid())
  programId    String
  program      Program              @relation(fields: [programId], references: [id], onDelete: Cascade)
  name         String
  order        Int                  @default(0)
  deliverables ProgramDeliverable[]

  @@index([programId])
}

model ProgramDeliverable {
  id          String        @id @default(cuid())
  programId   String
  program     Program       @relation(fields: [programId], references: [id], onDelete: Cascade)
  phaseId     String?
  phase       ProgramPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  name        String
  description String?
  mandatory   Boolean       @default(true)
  order       Int           @default(0)

  @@index([programId])
}

model ProgramRegion {
  id        String  @id @default(cuid())
  programId String
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  name      String
  notes     String?

  @@index([programId])
}

model ProgramEligibleLegalForm {
  id        String  @id @default(cuid())
  programId String
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  name      String

  @@index([programId])
}

model ProgramRequiredForm {
  id         String  @id @default(cuid())
  programId  String
  program    Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  name       String                              // π.χ. «Ε3», «Βεβαίωση έναρξης» (from extraction or manual)
  mandatory  Boolean @default(true)
  notes      String?
  order      Int     @default(0)
  templateId String?                             // optional link to a «Οδηγός Εντύπου» (TaxFormTemplate)
  template   TaxFormTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([programId])
  @@index([templateId])
}

enum ApplicationStage {
  ASSESSMENT
  DOCUMENTS
  EXPENSES_DELIVERABLES
  OPSKE_SUBMISSION
  INSPECTION
  MONITORING
}

enum ObligationKind {
  DELIVERABLE
  FORM
  CRITERION
  TASK
  CUSTOM
}

enum ObligationStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
  WAIVED
}

enum AssessmentVerdict {
  PENDING
  ELIGIBLE
  INELIGIBLE
}

model ProgramApplication {
  id          String           @id @default(cuid())
  trdrId      String
  trdr        Trdr             @relation(fields: [trdrId], references: [id], onDelete: Cascade)
  programId   String
  program     Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  status      String           @default("ACTIVE")
  notes       String?
  createdById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  expenses    ProgramExpense[]

  stage              ApplicationStage @default(ASSESSMENT)
  managerId          String?
  manager            User? @relation("AppManager",   fields: [managerId],   references: [id], onDelete: SetNull)
  processorId        String?
  processor          User? @relation("AppProcessor", fields: [processorId], references: [id], onDelete: SetNull)
  assessmentScore    Float?
  assessmentMaxScore Float?
  assessmentVerdict  AssessmentVerdict @default(PENDING)
  opskeStatus        String?
  opskeRef           String?
  opskeSubmittedAt   DateTime?
  obligations        ApplicationObligation[]
  documents          ApplicationDocument[]
  criterionScores    ApplicationCriterionScore[]

  @@unique([trdrId, programId])
  @@index([trdrId])
  @@index([programId])
}

model ProgramExpense {
  id                   String                  @id @default(cuid())
  applicationId        String
  application          ProgramApplication      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  description          String
  amount               Decimal                 @db.Decimal(18, 2)
  vatAmount            Decimal?                @db.Decimal(18, 2)
  date                 DateTime?
  vendor               String?
  vendorAfm            String?
  docNumber            String?
  suggestedCategoryId  String?
  suggestionReason     String?
  suggestionConfidence Float?
  suggestionSource     ExpenseSuggestSource?
  categoryId           String?
  category             ProgramExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  confirmed            Boolean                 @default(false)
  createdById          String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  @@index([applicationId])
  @@index([categoryId])
}

model ApplicationObligation {
  id            String   @id @default(cuid())
  applicationId String
  application   ProgramApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  stage         ApplicationStage
  kind          ObligationKind @default(TASK)
  sourceId      String?
  name          String
  mandatory     Boolean @default(true)
  status        ObligationStatus @default(PENDING)
  dueDate       DateTime?
  assigneeId    String?
  assignee      User? @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  notes         String?
  order         Int @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  documents     ApplicationDocument[]

  @@index([applicationId])
  @@index([applicationId, stage])
  @@index([status])
}

model ApplicationDocument {
  id            String   @id @default(cuid())
  applicationId String
  application   ProgramApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  obligationId  String?
  obligation    ApplicationObligation? @relation(fields: [obligationId], references: [id], onDelete: SetNull)
  name          String
  storageKey    String
  mimeType      String?
  size          Int?
  uploadedById  String?
  uploadedAt    DateTime @default(now())

  @@index([applicationId])
  @@index([obligationId])
}

model ApplicationCriterionScore {
  id            String   @id @default(cuid())
  applicationId String
  application   ProgramApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  criterionId   String?
  name          String
  weight        Float @default(1)
  score         Float?
  maxScore      Float @default(100)
  note          String?
  order         Int @default(0)

  @@unique([applicationId, criterionId])
  @@index([applicationId])
}
