# Αντέγραψέ το σε .env και συμπλήρωσε τις τιμές. Το .env είναι gitignored.

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/damask?schema=public

# ── DeepSeek ──────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# ── BunnyCDN ──────────────────────────────────────────────
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_PASSWORD=
BUNNY_STORAGE_API=https://storage.bunnycdn.com
BUNNY_S3_ENDPOINT=https://de-s3.storage.bunnycdn.com
BUNNY_PULL_ZONE_URL=

# ── Auth.js ───────────────────────────────────────────────
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ── SoftOne oncloud ───────────────────────────────────────
S1_SERIAL=
S1_USERNAME=
S1_PASSWORD=
S1_APP_ID=
S1_COMPANY=
S1_BRANCH=
S1_MODULE=
S1_REFID=

# ── Χάρτες & Geocoding (Ρυθμίσεις → Χάρτες & Geocoding υπερισχύει αν οριστεί) ──
GOOGLE_MAPS_API_KEY=
MAPTILER_API_KEY=
GEOCODE_API=
GEMI_API_KEY=

# ── DB Backups (προαιρετικό) ──────────────────────────────
# Retention/prefix/διαδρομές pg_dump·pg_restore ρυθμίζονται κανονικά από το
# UI (Ρυθμίσεις → Backups). Αυτά τα 2 env vars είναι ΜΟΝΟ fallback όταν δεν
# έχει οριστεί αντίστοιχο setting — χρήσιμα σε container/CI όπου το binary
# δεν είναι στο τυπικό Homebrew path (βλ. src/lib/backup.ts resolvePgBinary).
# PG_DUMP=/usr/lib/postgresql/16/bin/pg_dump
# PG_RESTORE=/usr/lib/postgresql/16/bin/pg_restore
