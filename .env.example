# Αντέγραψέ το σε .env και συμπλήρωσε τις τιμές. Το .env είναι gitignored.

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/damask?schema=public

# ── DeepSeek ──────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# ── BunnyCDN ──────────────────────────────────────────────
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_PASSWORD=
BUNNY_STORAGE_API=https://storage.bunnycdn.com
BUNNY_S3_ENDPOINT=https://de-s3.storage.bunnycdn.com
BUNNY_PULL_ZONE_URL=

# ── Auth.js ───────────────────────────────────────────────
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ── SoftOne oncloud ───────────────────────────────────────
S1_SERIAL=
S1_USERNAME=
S1_PASSWORD=
S1_APP_ID=
S1_COMPANY=
S1_BRANCH=
S1_MODULE=
S1_REFID=
